<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ===== Auth screen shared styles ===== -->

    <!-- H1 page title (~24sp bold) -->
    <style name="Auth.Title">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Subtitle (14sp secondary) -->
    <style name="Auth.Subtitle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Field label (14sp medium, primary) -->
    <style name="Auth.FieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <!-- Outlined text input, radius 10, accent focus -->
    <style name="Auth.InputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxStrokeColor">@color/accent</item>
        <item name="boxStrokeErrorColor">@color/error_red</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_subtle</item>
        <item name="endIconTint">@color/text_secondary</item>
        <item name="errorTextColor">@color/error_red</item>
    </style>

    <style name="Auth.InputEditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHighlight">@color/accent_soft</item>
        <item name="android:textSize">16sp</item>
    </style>

    <!-- PRIMARY button: text-fill color (near-black light / near-white dark),
         label color flips too. Height ~52, radius 11. NOT amber. -->
    <style name="Auth.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/btn_primary_label</item>
        <item name="backgroundTint">@color/btn_primary_fill</item>
        <item name="cornerRadius">11dp</item>
        <item name="rippleColor">@color/accent_soft</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- SECONDARY (Google) button: surface fill + 1px border_strong -->
    <style name="Auth.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="strokeColor">@color/border_strong</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">11dp</item>
        <item name="rippleColor">@color/surface_hover</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">10dp</item>
        <item name="iconTint">@null</item>
    </style>

    <!-- Text link button (amber) -->
    <style name="Auth.LinkButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">@color/accent_soft</item>
    </style>

    <!-- Legal footer (12sp subtle) -->
    <style name="Auth.LegalFooter">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_subtle</item>
        <item name="android:gravity">center</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <!-- Field helper text (12sp subtle) -->
    <style name="Auth.HelperText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_subtle</item>
    </style>

    <!-- App-bar brand wordmark ("Capital Wizard"), 15sp medium -->
    <style name="Auth.BrandWordmark">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.006</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
    </style>

    <!-- Locale pill: surface fill + 1px border, fully rounded, flag + code +
         chevron. Tapping opens the language PopupMenu (see AuthActivity). -->
    <style name="Auth.LocalePill" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingStart">11dp</item>
        <item name="android:paddingEnd">9dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="strokeColor">@color/border</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">17dp</item>
        <item name="rippleColor">@color/surface_hover</item>
        <item name="icon">@drawable/ic_chevron_down</item>
        <item name="iconGravity">textEnd</item>
        <item name="iconSize">13dp</item>
        <item name="iconPadding">5dp</item>
        <item name="iconTint">@color/text_secondary</item>
    </style>

</resources>
