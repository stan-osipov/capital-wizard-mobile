<?xml version="1.0" encoding="utf-8"?>
<!-- Draws the amber "line" path of ic_splash_w by animating trimPathEnd 0 -> 1.
     Duration 900ms with the design's cubic-bezier(0.65,0,0.35,1) easing.
     Plays once via the system splash, then holds the final (fully drawn) frame. -->
<objectAnimator xmlns:android="http://schemas.android.com/apk/res/android"
    android:propertyName="trimPathEnd"
    android:valueType="floatType"
    android:valueFrom="0"
    android:valueTo="1"
    android:duration="900"
    android:interpolator="@interpolator/splash_w_easing" />
