<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Top app bar: brand lockup (start) + locale pill (end) -->
    <include
        android:id="@+id/app_bar"
        layout="@layout/include_auth_appbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/app_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:maxWidth="400dp"
                android:orientation="vertical">

                <TextView
                    style="@style/Auth.Title"
                    android:text="@string/reset_title" />

                <TextView
                    style="@style/Auth.Subtitle"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="@string/reset_subtitle" />

                <!-- ===== Form ===== -->
                <LinearLayout
                    android:id="@+id/reset_form"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/Auth.FieldLabel"
                        android:text="@string/field_email" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_email"
                        style="@style/Auth.InputLayout"
                        android:layout_marginBottom="20dp"
                        android:hint="@string/hint_email_example">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/input_email"
                            style="@style/Auth.InputEditText"
                            android:autofillHints="emailAddress"
                            android:imeOptions="actionDone"
                            android:inputType="textEmailAddress" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_send_reset"
                        style="@style/Auth.PrimaryButton"
                        android:text="@string/reset_button" />

                </LinearLayout>

                <!-- ===== Success state (hidden initially) ===== -->
                <LinearLayout
                    android:id="@+id/success_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingVertical="8dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reset_success_title"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:lineSpacingExtra="3dp"
                        android:text="@string/reset_success_description"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Back to sign in -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_back_to_login"
                    style="@style/Auth.LinkButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="20dp"
                    android:text="@string/reset_back" />

                <!-- Legal footer -->
                <TextView
                    android:id="@+id/legal_footer"
                    style="@style/Auth.LegalFooter"
                    android:layout_marginTop="24dp"
                    android:paddingHorizontal="12dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@color/accent"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
